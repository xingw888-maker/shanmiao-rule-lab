{
  "id": "construction-general-contract",
  "name": "建设工程一般规则包",
  "version": "1.0.0",
  "domain": "construction",
  "maintainer": "manual-audited",
  "description": "适用所有建设工程合同类型的通用规则包。覆盖屋面防水保修、电气管线保修、给排水管道保修、质保金比例、缺陷责任期、竣工验收组织期限、违约金比率、付款比例、保修书、竣工验收条款、安全生产条款、计价一致性、责任一致性、付款逾期利息、争议解决、付款条件、违约金基数、质保期起算。24条规则，全部手工审核，L0_VALIDATED。",
  "disclaimer": "本规则包仅提供辅助初审建议，校验结果不具备法律效力。所有结论均应经过专业律师独立审核确认。",
  "applicable_contract_types": [],
  "rules": [
    {
      "id": "cn-001",
      "clause_type": "保修",
      "name": "屋面防水工程保修期限",
      "condition": {
        "type": "numeric_comparison",
        "label": "屋面防水保修期",
        "context_pattern": "屋面.*防水.*保修[^，。；;]{0,10}[五5]|屋面.*防水.*保修期限[^，。；;]{0,10}[五5]",
        "unit": "年",
        "operator": ">=",
        "expected": 5,
        "legal_ref": "国务院令第279号第40条(二)"
      },
      "severity": "fatal",
      "message": "屋面防水最低保修期限为5年",
      "category": "保修期限",
      "source": "国务院",
      "source_credibility": 1.0,
      "extraction_method": "structured",
      "structured_template": "numeric_warranty_is",
      "scope": {
        "contract_types": [
          "屋面防水工程",
          "大型工程",
          "总承包工程"
        ],
        "exclude_contract_types": [
          "维修工程",
          "购销合同"
        ],
        "min_contract_value": 0,
        "note": "屋面防水保修5年，小维修合同不适用"
      },
      "legal_hierarchy": "admin_regulation"
    },
