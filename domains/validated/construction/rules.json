    {
      "id": "cn-010",
      "clause_type": "付款",
      "name": "付款比例合计一致性",
      "condition": {
        "type": "sum_numeric_comparison",
        "label": "付款比例合计",
        "context_pattern": "(?:预付款|进度款|结算款|工程款).*?[至为].*?%|付款至.*?%|支付至.*?%|付至.*?%",
        "unit": "%",
        "operator": "<=",
        "expected": 105,
        "legal_ref": "GF-2017-0201第12条 合同惯例"
      },
      "severity": "major",
      "message": "付款比例合计不应超过100%（含增值税等附加比例后不超过110%）",
      "category": "工程款",
      "source": "合同惯例",
      "source_credibility": 0.8,
      "extraction_method": "structured",
      "scope": {
        "contract_types": [
          "大型工程",
          "总承包工程"
        ],
        "exclude_contract_types": [],
        "min_contract_value": 100000,
        "note": "付款比例仅适用大型/总承包合同。放宽至110%以容忍增值税税率等非付款比例干扰"
      },
      "structured_template": "sum_numeric_not_exceed",
      "legal_hierarchy": "industry_standard"
    },
